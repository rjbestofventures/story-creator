{
  "mcpServers": {
    "shadcn-vue": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "shadcn-vue@latest",
        "mcp"
      ],
      "env": {}
    },
    "figma": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "figma-developer-mcp",
        "--stdio"
      ],
      "env": {
        "FIGMA_API_KEY": "${FIGMA_API_KEY}"
      }
    }
  }
}